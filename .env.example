# ============================================
# Lashed by Amarah - Environment Configuration
# ============================================

# Copy this file to .env and fill in with your actual values
# DO NOT commit .env file to version control

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=lash_bookings

# ============================================
# M-PESA CONFIGURATION
# ============================================

# M-Pesa Environment (sandbox or production)
MPESA_ENVIRONMENT=sandbox

# Daraja API Credentials
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Business Configuration
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a503b6e

# Callback URL (where M-Pesa will send payment confirmations)
# Must be publicly accessible and HTTPS in production
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# ============================================
# SMS NOTIFICATIONS (Optional)
# ============================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@lashedbyamarah.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ============================================
# SANDBOX TEST CREDENTIALS
# ============================================
# Use these for testing before production

# Test Phone Numbers (for sandbox)
TEST_PHONE_1=254708374149
TEST_PHONE_2=254722000000
TEST_PHONE_3=254729674567

# Test M-Pesa PIN
TEST_MPESA_PIN=1234
