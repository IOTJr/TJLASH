# ============================================
# Lashed by Amarah - Environment Configuration
# ============================================

# Copy this file to .env and fill in with your actual values
# DO NOT commit .env file to version control

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=lash_bookings

# ============================================
# INTASEND CONFIGURATION
# ============================================

# IntaSend API credentials
# Get these from the IntaSend dashboard
INTASEND_SECRET_KEY=your_secret_key_here
INTASEND_PUBLISHABLE_KEY=your_publishable_key_here

# IntaSend environment (sandbox or production)
INTASEND_ENVIRONMENT=sandbox
INTASEND_BASE_URL=https://sandbox.intasend.com

# Optional account / wallet settings
INTASEND_WALLET_ID=your_wallet_id_here
INTASEND_MOBILE_TARRIF=BUSINESS-PAYS

# Webhook URL for payment confirmation
# Must be publicly accessible and HTTPS in production
INTASEND_WEBHOOK_URL=https://yourdomain.com/api/intasend/webhook
INTASEND_WEBHOOK_CHALLENGE=n4n0-systems-intasend-2026

# ============================================
# SMS NOTIFICATIONS (Optional)
# ============================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@lashedbyamarah.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ============================================
# SANDBOX TEST CREDENTIALS
# ============================================
# Use these for testing before production

# Test Phone Numbers (for sandbox)
TEST_PHONE_1=254708374149
TEST_PHONE_2=254722000000
TEST_PHONE_3=254729674567

# Test M-Pesa PIN
TEST_MPESA_PIN=1234
